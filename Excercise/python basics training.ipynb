","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 1. Variables \u0026 Data Types\\n\",","    \"\\n\",","    \"A **variable** is a named container for storing data. Python has four core data types:\\n\",","    \"\\n\",","    \"| Type | Example | Use Case |\\n\",","    \"|------|---------|----------|\\n\",","    \"| `int` | `42` | Age, quantity, count |\\n\",","    \"| `float` | `3.99` | Price, temperature, weight |\\n\",","    \"| `str` | `\\\"Alice\\\"` | Names, messages, labels |\\n\",","    \"| `bool` | `True` / `False` | Flags, on/off states |\\n\",","    \"\\n\",","    \"### 🛒 Scenario: Setting up a product listing for an online store\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Product details for an online store\\n\",","    \"product_name = \\\"Wireless Headphones\\\"   # str\\n\",","    \"price = 79.99                           # float\\n\",","    \"stock_quantity = 150                    # int\\n\",","    \"is_available = True                     # bool\\n\",","    \"\\n\",","    \"print(\\\"Product:\\\", product_name)\\n\",","    \"print(\\\"Price: $\\\", price)\\n\",","    \"print(\\\"In Stock:\\\", stock_quantity, \\\"units\\\")\\n\",","    \"print(\\\"Available for purchase:\\\", is_available)\\n\",","    \"print(\\\"\\\\nData types:\\\")\\n\",","    \"print(type(product_name), type(price), type(stock_quantity), type(is_available))\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 1\\n\",","    \"Create variables for a **new product** of your choice. Include its name, price, quantity, and whether it's on sale. Then print them all out.\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Your code here\\n\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 2. Strings \u0026 String Methods\\n\",","    \"\\n\",","    \"Strings are sequences of characters. Python gives you many built-in methods to manipulate them.\\n\",","    \"\\n\",","    \"### 📧 Scenario: Processing customer sign-up form data\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Raw input from a sign-up form (often messy!)\\n\",","    \"raw_name = \\\"   john doe   \\\"\\n\",","    \"raw_email = \\\"  JOHN.DOE@GMAIL.COM  \\\"\\n\",","    \"city = \\\"new york\\\"\\n\",","    \"\\n\",","    \"# Clean and format the data\\n\",","    \"clean_name = raw_name.strip().title()       # Remove spaces, capitalize properly\\n\",","    \"clean_email = raw_email.strip().lower()     # Remove spaces, lowercase\\n\",","    \"clean_city = city.upper()                   # Uppercase for display labels\\n\",","    \"\\n\",","    \"print(\\\"=== Customer Profile ===\\\")\\n\",","    \"print(\\\"Name:\\\", clean_name)\\n\",","    \"print(\\\"Email:\\\", clean_email)\\n\",","    \"print(\\\"City:\\\", clean_city)\\n\",","    \"\\n\",","    \"# String formatting with f-strings\\n\",","    \"welcome_message = f\\\"Welcome, {clean_name}! Your account has been created with {clean_email}.\\\"\\n\",","    \"print(\\\"\\\\n\\\" + welcome_message)\\n\",","    \"\\n\",","    \"# Useful string checks\\n\",","    \"print(\\\"\\\\nEmail contains '@':\\\", \\\"@\\\" in clean_email)\\n\",","    \"print(\\\"Name starts with 'John':\\\", clean_name.startswith(\\\"John\\\"))\\n\",","    \"print(\\\"Character count in name:\\\", len(clean_name))\\n\",","    \"print(\\\"Replace domain:\\\", clean_email.replace(\\\"gmail.com\\\", \\\"company.com\\\"))\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 2\\n\",","    \"You receive this messy survey response: `\\\"  i LOVE this product!! \\\"`. Clean it up and print:\\n\",","    \"- The response in title case\\n\",","    \"- Its character length (after stripping spaces)\\n\",","    \"- Whether it contains the word \\\"love\\\" (case-insensitive)\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"response = \\\"  i LOVE this product!! \\\"\\n\",","    \"# Your code here\\n\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 3. Numbers \u0026 Math Operations\\n\",","    \"\\n\",","    \"Python handles arithmetic naturally, plus has a `math` module for advanced operations.\\n\",","    \"\\n\",","    \"| Operator | Meaning | Example |\\n\",","    \"|----------|---------|--------|\\n\",","    \"| `+` `-` `*` `/` | Basic math | `10 / 3` → `3.333` |\\n\",","    \"| `//` | Floor division | `10 // 3` → `3` |\\n\",","    \"| `%` | Modulo (remainder) | `10 % 3` → `1` |\\n\",","    \"| `**` | Power | `2 ** 8` → `256` |\\n\",","    \"\\n\",","    \"### ☕ Scenario: Running a coffee shop — daily sales calculations\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Daily coffee shop numbers\\n\",","    \"espresso_sold = 84\\n\",","    \"latte_sold = 57\\n\",","    \"espresso_price = 2.50\\n\",","    \"latte_price = 4.75\\n\",","    \"rent_daily = 120\\n\",","    \"staff_daily = 200\\n\",","    \"supplies_daily = 85\\n\",","    \"\\n\",","    \"# Revenue\\n\",","    \"espresso_revenue = espresso_sold * espresso_price\\n\",","    \"latte_revenue = latte_sold * latte_price\\n\",","    \"total_revenue = espresso_revenue + latte_revenue\\n\",","    \"\\n\",","    \"# Costs \u0026 profit\\n\",","    \"total_costs = rent_daily + staff_daily + supplies_daily\\n\",","    \"profit = total_revenue - total_costs\\n\",","    \"profit_margin = (profit / total_revenue) * 100\\n\",","    \"\\n\",","    \"# Average spend per customer\\n\",","    \"total_customers = espresso_sold + latte_sold\\n\",","    \"avg_spend = total_revenue / total_customers\\n\",","    \"\\n\",","    \"print(\\\"=== Daily Coffee Shop Report ===\\\")\\n\",","    \"print(f\\\"Espresso Revenue:  ${espresso_revenue:.2f}\\\")\\n\",","    \"print(f\\\"Latte Revenue:     ${latte_revenue:.2f}\\\")\\n\",","    \"print(f\\\"Total Revenue:     ${total_revenue:.2f}\\\")\\n\",","    \"print(f\\\"Total Costs:       ${total_costs:.2f}\\\")\\n\",","    \"print(f\\\"Net Profit:        ${profit:.2f}\\\")\\n\",","    \"print(f\\\"Profit Margin:     {profit_margin:.1f}%\\\")\\n\",","    \"print(f\\\"Avg Spend/Customer:${avg_spend:.2f}\\\")\\n\",","    \"print(f\\\"\\\\nCustomers served: {total_customers}\\\")\\n\",","    \"print(f\\\"Remaining stock batches (5 shots each): {espresso_sold // 5} full batches, {espresso_sold % 5} leftover shots\\\")\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 3\\n\",","    \"A gym charges **$45/month** for membership. They have **320 members**. Their monthly costs are: rent $3,200, staff $8,500, equipment maintenance $600.\\n\",","    \"- Calculate total monthly revenue\\n\",","    \"- Calculate total monthly costs\\n\",","    \"- Calculate profit and profit margin (as a percentage, rounded to 1 decimal)\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Your code here\\n\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 4. Lists\\n\",","    \"\\n\",","    \"A **list** is an ordered, changeable collection. Think of it like a to-do list or a shopping cart.\\n\",","    \"\\n\",","    \"### 🛍️ Scenario: Managing a shopping cart\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Start with a shopping cart\\n\",","    \"cart = [\\\"apples\\\", \\\"milk\\\", \\\"bread\\\", \\\"eggs\\\", \\\"butter\\\"]\\n\",","    \"prices = [1.20, 2.50, 3.00, 4.50, 2.80]\\n\",","    \"\\n\",","    \"print(\\\"Original cart:\\\", cart)\\n\",","    \"print(\\\"Number of items:\\\", len(cart))\\n\",","    \"print(\\\"First item:\\\", cart[0])\\n\",","    \"print(\\\"Last item:\\\", cart[-1])\\n\",","    \"print(\\\"First 3 items:\\\", cart[:3])\\n\",","    \"\\n\",","    \"# Modify the cart\\n\",","    \"cart.append(\\\"orange juice\\\")          # Add to end\\n\",","    \"prices.append(3.99)\\n\",","    \"cart.insert(1, \\\"yogurt\\\")             # Add at position\\n\",","    \"prices.insert(1, 1.75)\\n\",","    \"cart.remove(\\\"butter\\\")                # Remove by value\\n\",","    \"prices.pop(4)                        # Remove by index (butter was at index 4 after insert)\\n\",","    \"\\n\",","    \"print(\\\"\\\\nUpdated cart:\\\", cart)\\n\",","    \"\\n\",","    \"# Useful operations\\n\",","    \"cart.sort()                          # Sort alphabetically\\n\",","    \"print(\\\"Sorted cart:\\\", cart)\\n\",","    \"\\n\",","    \"total = sum(prices)\\n\",","    \"print(f\\\"\\\\nCart total: ${total:.2f}\\\")\\n\",","    \"print(f\\\"Cheapest item: ${min(prices):.2f}\\\")\\n\",","    \"print(f\\\"Most expensive: ${max(prices):.2f}\\\")\\n\",","    \"print(\\\"Is 'milk' in cart?\\\", \\\"milk\\\" in cart)\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 4\\n\",","    \"You have a list of **student test scores**: `[72, 88, 95, 61, 79, 84, 90, 55, 68, 77]`\\n\",","    \"- Find the highest and lowest score\\n\",","    \"- Calculate the average score (round to 1 decimal)\\n\",","    \"- Sort the scores from highest to lowest\\n\",","    \"- Print how many students scored above 80\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"scores = [72, 88, 95, 61, 79, 84, 90, 55, 68, 77]\\n\",","    \"# Your code here\\n\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 5. Dictionaries\\n\",","    \"\\n\",","    \"A **dictionary** stores data as **key-value pairs** — perfect for structured records like employee profiles, product info, or config settings.\\n\",","    \"\\n\",","    \"### 👩‍💼 Scenario: Employee management system\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# An employee record\\n\",","    \"employee = {\\n\",","    \"    \\\"id\\\": \\\"EMP-4821\\\",\\n\",","    \"    \\\"name\\\": \\\"Sarah Chen\\\",\\n\",","    \"    \\\"department\\\": \\\"Engineering\\\",\\n\",","    \"    \\\"salary\\\": 95000,\\n\",","    \"    \\\"skills\\\": [\\\"Python\\\", \\\"SQL\\\", \\\"Machine Learning\\\"],\\n\",","    \"    \\\"is_manager\\\": False\\n\",","    \"}\\n\",","    \"\\n\",","    \"# Access values\\n\",","    \"print(\\\"Name:\\\", employee[\\\"name\\\"])\\n\",","    \"print(\\\"Department:\\\", employee.get(\\\"department\\\"))\\n\",","    \"print(\\\"Location:\\\", employee.get(\\\"location\\\", \\\"Not specified\\\"))  # Safe default\\n\",","    \"\\n\",","    \"# Modify\\n\",","    \"employee[\\\"salary\\\"] = 102000          # Give Sarah a raise!\\n\",","    \"employee[\\\"is_manager\\\"] = True\\n\",","    \"employee[\\\"skills\\\"].append(\\\"Leadership\\\")\\n\",","    \"\\n\",","    \"print(\\\"\\\\n=== Updated Employee Record ===\\\")\\n\",","    \"for key, value in employee.items():\\n\",","    \"    print(f\\\"  {key}: {value}\\\")\\n\",","    \"\\n\",","    \"# Multiple employees\\n\",","    \"team = [\\n\",","    \"    {\\\"name\\\": \\\"Sarah Chen\\\", \\\"salary\\\": 102000, \\\"dept\\\": \\\"Engineering\\\"},\\n\",","    \"    {\\\"name\\\": \\\"Marcus Lee\\\", \\\"salary\\\": 87000,  \\\"dept\\\": \\\"Marketing\\\"},\\n\",","    \"    {\\\"name\\\": \\\"Priya Patel\\\",\\\"salary\\\": 91000,  \\\"dept\\\": \\\"Engineering\\\"},\\n\",","    \"]\\n\",","    \"\\n\",","    \"total_payroll = sum(e[\\\"salary\\\"] for e in team)\\n\",","    \"print(f\\\"\\\\nTotal team payroll: ${total_payroll:,}\\\")\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 5\\n\",","    \"Create a dictionary for a **restaurant menu item**: a burger with a name, price, calories, ingredients (list), and whether it's vegetarian. Then:\\n\",","    \"- Print each field with a label\\n\",","    \"- Add a new ingredient to the list\\n\",","    \"- Apply a 10% price increase and print the new price\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Your code here\\n\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 6. Conditional Logic (if / elif / else)\\n\",","    \"\\n\",","    \"Conditions let your program make decisions based on data.\\n\",","    \"\\n\",","    \"### 🏦 Scenario: Bank loan eligibility checker\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"def check_loan_eligibility(credit_score, annual_income, existing_debt):\\n\",","    \"    \\\"\\\"\\\"Determines loan eligibility and interest rate based on financial profile.\\\"\\\"\\\"\\n\",","    \"    \\n\",","    \"    debt_to_income = (existing_debt / annual_income) * 100\\n\",","    \"    \\n\",","    \"    print(f\\\"Credit Score: {credit_score}\\\")\\n\",","    \"    print(f\\\"Annual Income: ${annual_income:,}\\\")\\n\",","    \"    print(f\\\"Debt-to-Income Ratio: {debt_to_income:.1f}%\\\")\\n\",","    \"    print()\\n\",","    \"    \\n\",","    \"    # Primary eligibility check\\n\",","    \"    if credit_score \u003c 580:\\n\",","    \"        print(\\\"❌ DECLINED: Credit score too low (minimum 580 required).\\\")\\n\",","    \"        print(\\\"   Tip: Pay down existing debts and avoid new credit inquiries.\\\")\\n\",","    \"    elif annual_income \u003c 30000:\\n\",","    \"        print(\\\"❌ DECLINED: Income below minimum threshold ($30,000/year).\\\")\\n\",","    \"    elif debt_to_income \u003e 43:\\n\",","    \"        print(\\\"❌ DECLINED: Debt-to-income ratio exceeds 43%.\\\")\\n\",","    \"        print(f\\\"   Need to reduce debt by ${existing_debt - annual_income * 0.43:,.0f}\\\")\\n\",","    \"    else:\\n\",","    \"        # Approved — determine interest rate tier\\n\",","    \"        if credit_score \u003e= 750:\\n\",","    \"            rate = 4.5\\n\",","    \"            tier = \\\"Excellent\\\"\\n\",","    \"        elif credit_score \u003e= 700:\\n\",","    \"            rate = 5.9\\n\",","    \"            tier = \\\"Good\\\"\\n\",","    \"        elif credit_score \u003e= 650:\\n\",","    \"            rate = 7.4\\n\",","    \"            tier = \\\"Fair\\\"\\n\",","    \"        else:\\n\",","    \"            rate = 9.9\\n\",","    \"            tier = \\\"Poor\\\"\\n\",","    \"        \\n\",","    \"        print(f\\\"✅ APPROVED! Credit tier: {tier}\\\")\\n\",","    \"        print(f\\\"   Interest rate: {rate}% APR\\\")\\n\",","    \"\\n\",","    \"# Test cases\\n\",","    \"print(\\\"=== Applicant 1: High earner, great credit ===\\\")\\n\",","    \"check_loan_eligibility(credit_score=780, annual_income=95000, existing_debt=15000)\\n\",","    \"\\n\",","    \"print(\\\"\\\\n=== Applicant 2: Low credit score ===\\\")\\n\",","    \"check_loan_eligibility(credit_score=540, annual_income=65000, existing_debt=10000)\\n\",","    \"\\n\",","    \"print(\\\"\\\\n=== Applicant 3: High debt ratio ===\\\")\\n\",","    \"check_loan_eligibility(credit_score=670, annual_income=45000, existing_debt=22000)\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 6\\n\",","    \"Write a program that takes a temperature in Celsius and prints a clothing recommendation:\\n\",","    \"- Below 0°C → \\\"Heavy coat, gloves, and hat\\\"\\n\",","    \"- 0–10°C → \\\"Warm jacket required\\\"\\n\",","    \"- 11–20°C → \\\"Light jacket or sweater\\\"\\n\",","    \"- 21–30°C → \\\"T-shirt weather!\\\"\\n\",","    \"- Above 30°C → \\\"Stay cool — shorts and sunscreen!\\\"\\n\",","    \"\\n\",","    \"Test it with at least 3 temperatures.\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"def clothing_recommendation(temp_celsius):\\n\",","    \"    # Your code here\\n\",","    \"    pass\\n\",","    \"\\n\",","    \"clothing_recommendation(-5)\\n\",","    \"clothing_recommendation(15)\\n\",","    \"clothing_recommendation(35)\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 7. Loops (for \u0026 while)\\n\",","    \"\\n\",","    \"Loops let you repeat actions — automating repetitive tasks.\\n\",","    \"\\n\",","    \"### 📦 Scenario: Processing an e-commerce order batch\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Batch of orders to process\\n\",","    \"orders = [\\n\",","    \"    {\\\"id\\\": \\\"ORD-001\\\", \\\"customer\\\": \\\"Alice\\\",  \\\"items\\\": 3, \\\"total\\\": 127.50, \\\"status\\\": \\\"pending\\\"},\\n\",","    \"    {\\\"id\\\": \\\"ORD-002\\\", \\\"customer\\\": \\\"Bob\\\",    \\\"items\\\": 1, \\\"total\\\":  45.00, \\\"status\\\": \\\"pending\\\"},\\n\",","    \"    {\\\"id\\\": \\\"ORD-003\\\", \\\"customer\\\": \\\"Carol\\\",  \\\"items\\\": 5, \\\"total\\\": 289.99, \\\"status\\\": \\\"pending\\\"},\\n\",","    \"    {\\\"id\\\": \\\"ORD-004\\\", \\\"customer\\\": \\\"David\\\",  \\\"items\\\": 2, \\\"total\\\":  88.00, \\\"status\\\": \\\"pending\\\"},\\n\",","    \"    {\\\"id\\\": \\\"ORD-005\\\", \\\"customer\\\": \\\"Eva\\\",    \\\"items\\\": 7, \\\"total\\\": 412.30, \\\"status\\\": \\\"pending\\\"},\\n\",","    \"]\\n\",","    \"\\n\",","    \"print(\\\"=== Processing Orders ===\\\")\\n\",","    \"total_revenue = 0\\n\",","    \"large_orders = []\\n\",","    \"\\n\",","    \"for order in orders:\\n\",","    \"    order[\\\"status\\\"] = \\\"processed\\\"\\n\",","    \"    total_revenue += order[\\\"total\\\"]\\n\",","    \"    \\n\",","    \"    if order[\\\"total\\\"] \u003e 200:\\n\",","    \"        large_orders.append(order[\\\"id\\\"])\\n\",","    \"        flag = \\\"🌟 VIP\\\"\\n\",","    \"    else:\\n\",","    \"        flag = \\\"✅\\\"\\n\",","    \"    \\n\",","    \"    print(f\\\"{flag} {order['id']} | {order['customer']:\u003c8} | {order['items']} items | ${order['total']:.2f}\\\")\\n\",","    \"\\n\",","    \"print(f\\\"\\\\nTotal Revenue: ${total_revenue:.2f}\\\")\\n\",","    \"print(f\\\"Large orders (\u003e$200): {large_orders}\\\")\\n\",","    \"\\n\",","    \"# Using enumerate to get index + value\\n\",","    \"print(\\\"\\\\n=== Order Rankings by Value ===\\\")\\n\",","    \"sorted_orders = sorted(orders, key=lambda x: x[\\\"total\\\"], reverse=True)\\n\",","    \"for rank, order in enumerate(sorted_orders, start=1):\\n\",","    \"    print(f\\\"  #{rank}: {order['customer']} — ${order['total']:.2f}\\\")\\n\",","    \"\\n\",","    \"# While loop — countdown timer / retry logic\\n\",","    \"print(\\\"\\\\n=== Payment Retry Simulation ===\\\")\\n\",","    \"attempts = 0\\n\",","    \"max_attempts = 3\\n\",","    \"payment_success = False\\n\",","    \"\\n\",","    \"while attempts \u003c max_attempts and not payment_success:\\n\",","    \"    attempts += 1\\n\",","    \"    print(f\\\"Attempt {attempts}/{max_attempts}...\\\", end=\\\" \\\")\\n\",","    \"    if attempts == 2:  # Simulate success on 2nd try\\n\",","    \"        payment_success = True\\n\",","    \"        print(\\\"Payment approved! ✅\\\")\\n\",","    \"    else:\\n\",","    \"        print(\\\"Failed, retrying...\\\")\\n\",","    \"\\n\",","    \"if not payment_success:\\n\",","    \"    print(\\\"Payment failed after all attempts. Please contact support.\\\")\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 7\\n\",","    \"You have a list of monthly temperatures (°C): `[3, 5, 8, 13, 18, 23, 26, 25, 20, 14, 8, 4]`\\n\",","    \"- Use a `for` loop to print each month name (Jan–Dec) and its temperature\\n\",","    \"- Count how many months were above 15°C\\n\",","    \"- Find the warmest and coldest months\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"temps = [3, 5, 8, 13, 18, 23, 26, 25, 20, 14, 8, 4]\\n\",","    \"months = [\\\"Jan\\\", \\\"Feb\\\", \\\"Mar\\\", \\\"Apr\\\", \\\"May\\\", \\\"Jun\\\",\\n\",","    \"          \\\"Jul\\\", \\\"Aug\\\", \\\"Sep\\\", \\\"Oct\\\", \\\"Nov\\\", \\\"Dec\\\"]\\n\",","    \"# Your code here\\n\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 8. Functions\\n\",","    \"\\n\",","    \"Functions are reusable blocks of code. They take **inputs (parameters)** and return **outputs**. Good functions do one thing well.\\n\",","    \"\\n\",","    \"### 🚗 Scenario: A ride-sharing fare calculator\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# Functions for a ride-sharing app\\n\",","    \"\\n\",","    \"def calculate_fare(distance_km, duration_min, is_peak_hour=False, vehicle_type=\\\"standard\\\"):\\n\",","    \"    \\\"\\\"\\\"\\n\",","    \"    Calculate ride fare based on distance, time, and conditions.\\n\",","    \"    \\n\",","    \"    Args:\\n\",","    \"        distance_km: Trip distance in kilometers\\n\",","    \"        duration_min: Trip duration in minutes\\n\",","    \"        is_peak_hour: True if during peak traffic hours\\n\",","    \"        vehicle_type: 'standard', 'premium', or 'xl'\\n\",","    \"    \\n\",","    \"    Returns:\\n\",","    \"        dict with fare breakdown\\n\",","    \"    \\\"\\\"\\\"\\n\",","    \"    BASE_FARE = {\\\"standard\\\": 2.50, \\\"premium\\\": 4.00, \\\"xl\\\": 3.50}\\n\",","    \"    PER_KM    = {\\\"standard\\\": 1.20, \\\"premium\\\": 2.00, \\\"xl\\\": 1.60}\\n\",","    \"    PER_MIN   = {\\\"standard\\\": 0.25, \\\"premium\\\": 0.40, \\\"xl\\\": 0.30}\\n\",","    \"    PEAK_MULTIPLIER = 1.5\\n\",","    \"    \\n\",","    \"    base = BASE_FARE[vehicle_type]\\n\",","    \"    distance_charge = distance_km * PER_KM[vehicle_type]\\n\",","    \"    time_charge = duration_min * PER_MIN[vehicle_type]\\n\",","    \"    subtotal = base + distance_charge + time_charge\\n\",","    \"    \\n\",","    \"    peak_surcharge = subtotal * (PEAK_MULTIPLIER - 1) if is_peak_hour else 0\\n\",","    \"    total = subtotal + peak_surcharge\\n\",","    \"    \\n\",","    \"    return {\\n\",","    \"        \\\"base_fare\\\": base,\\n\",","    \"        \\\"distance_charge\\\": distance_charge,\\n\",","    \"        \\\"time_charge\\\": time_charge,\\n\",","    \"        \\\"peak_surcharge\\\": peak_surcharge,\\n\",","    \"        \\\"total\\\": total\\n\",","    \"    }\\n\",","    \"\\n\",","    \"\\n\",","    \"def format_fare_receipt(fare_breakdown, vehicle_type):\\n\",","    \"    \\\"\\\"\\\"Prints a formatted receipt for a ride.\\\"\\\"\\\"\\n\",","    \"    print(f\\\"Vehicle: {vehicle_type.capitalize()}\\\")\\n\",","    \"    print(f\\\"  Base fare:        ${fare_breakdown['base_fare']:.2f}\\\")\\n\",","    \"    print(f\\\"  Distance charge:  ${fare_breakdown['distance_charge']:.2f}\\\")\\n\",","    \"    print(f\\\"  Time charge:      ${fare_breakdown['time_charge']:.2f}\\\")\\n\",","    \"    if fare_breakdown['peak_surcharge'] \u003e 0:\\n\",","    \"        print(f\\\"  Peak surcharge:   ${fare_breakdown['peak_surcharge']:.2f}\\\")\\n\",","    \"    print(f\\\"  {'─'*30}\\\")\\n\",","    \"    print(f\\\"  TOTAL:            ${fare_breakdown['total']:.2f}\\\")\\n\",","    \"\\n\",","    \"\\n\",","    \"# Test the functions\\n\",","    \"print(\\\"=== Ride 1: Airport trip, peak hour ===\\\")\\n\",","    \"fare1 = calculate_fare(distance_km=18.5, duration_min=35, is_peak_hour=True, vehicle_type=\\\"premium\\\")\\n\",","    \"format_fare_receipt(fare1, \\\"premium\\\")\\n\",","    \"\\n\",","    \"print(\\\"\\\\n=== Ride 2: Short city hop, off-peak ===\\\")\\n\",","    \"fare2 = calculate_fare(distance_km=4.2, duration_min=12)\\n\",","    \"format_fare_receipt(fare2, \\\"standard\\\")\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 8\\n\",","    \"Write a function `bmi_calculator(weight_kg, height_m)` that:\\n\",","    \"- Calculates BMI (weight / height²)\\n\",","    \"- Returns a dictionary with the BMI value and category:\\n\",","    \"  - Under 18.5 → Underweight\\n\",","    \"  - 18.5–24.9 → Normal weight\\n\",","    \"  - 25–29.9 → Overweight\\n\",","    \"  - 30+ → Obese\\n\",","    \"- Test it with at least 3 different people\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"def bmi_calculator(weight_kg, height_m):\\n\",","    \"    # Your code here\\n\",","    \"    pass\\n\",","    \"\\n\",","    \"# Test your function\\n\",","    \"print(bmi_calculator(70, 1.75))\\n\",","    \"print(bmi_calculator(50, 1.68))\\n\",","    \"print(bmi_calculator(95, 1.70))\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 9. Error Handling (try / except)\\n\",","    \"\\n\",","    \"Real programs deal with unexpected input. Error handling keeps your app running gracefully.\\n\",","    \"\\n\",","    \"### 🔐 Scenario: Validating user input in a registration form\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"def parse_age(age_input):\\n\",","    \"    \\\"\\\"\\\"Safely converts age input to integer.\\\"\\\"\\\"\\n\",","    \"    try:\\n\",","    \"        age = int(age_input)\\n\",","    \"        if age \u003c 0 or age \u003e 120:\\n\",","    \"            raise ValueError(f\\\"Age {age} is out of realistic range.\\\")\\n\",","    \"        return age\\n\",","    \"    except ValueError as e:\\n\",","    \"        print(f\\\"⚠️  Invalid age input: '{age_input}' → {e}\\\")\\n\",","    \"        return None\\n\",","    \"\\n\",","    \"\\n\",","    \"def process_payment(amount_str):\\n\",","    \"    \\\"\\\"\\\"Processes a payment amount from string input.\\\"\\\"\\\"\\n\",","    \"    try:\\n\",","    \"        amount = float(amount_str.replace(\\\"$\\\", \\\"\\\").replace(\\\",\\\", \\\"\\\"))\\n\",","    \"        if amount \u003c= 0:\\n\",","    \"            raise ValueError(\\\"Amount must be positive.\\\")\\n\",","    \"        print(f\\\"✅ Payment of ${amount:.2f} processed successfully.\\\")\\n\",","    \"        return amount\\n\",","    \"    except ValueError as e:\\n\",","    \"        print(f\\\"❌ Payment error: {e}\\\")\\n\",","    \"        return 0\\n\",","    \"    except Exception as e:\\n\",","    \"        print(f\\\"❌ Unexpected error: {e}\\\")\\n\",","    \"        return 0\\n\",","    \"    finally:\\n\",","    \"        print(\\\"   (Transaction log saved)\\\")  # Always runs\\n\",","    \"\\n\",","    \"\\n\",","    \"# Test age parsing\\n\",","    \"print(\\\"=== Age Validation ===\\\")\\n\",","    \"for test in [\\\"25\\\", \\\"abc\\\", \\\"-3\\\", \\\"200\\\", \\\"42\\\"]:\\n\",","    \"    result = parse_age(test)\\n\",","    \"    if result:\\n\",","    \"        print(f\\\"✅ Valid age: {result}\\\")\\n\",","    \"\\n\",","    \"# Test payment processing\\n\",","    \"print(\\\"\\\\n=== Payment Processing ===\\\")\\n\",","    \"process_payment(\\\"$1,250.00\\\")\\n\",","    \"process_payment(\\\"hello\\\")\\n\",","    \"process_payment(\\\"-50\\\")\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"### ✏️ Exercise 9\\n\",","    \"Write a function `safe_divide(a, b)` that:\\n\",","    \"- Returns the result of `a / b`\\n\",","    \"- Handles division by zero with a clear message\\n\",","    \"- Handles non-numeric inputs\\n\",","    \"- Returns `None` on error\\n\",","    \"\\n\",","    \"Test it with: `(10, 2)`, `(5, 0)`, `(\\\"ten\\\", 2)`, `(100, 4)`\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"def safe_divide(a, b):\\n\",","    \"    # Your code here\\n\",","    \"    pass\\n\",","    \"\\n\",","    \"print(safe_divide(10, 2))\\n\",","    \"print(safe_divide(5, 0))\\n\",","    \"print(safe_divide(\\\"ten\\\", 2))\\n\",","    \"print(safe_divide(100, 4))\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"metadata\": {},","   \"source\": [","    \"---\\n\",","    \"## 🏁 Mini-Project: Personal Expense Tracker\\n\",","    \"\\n\",","    \"Put it all together! Build a simple expense tracker that uses everything you've learned.\\n\",","    \"\\n\",","    \"\u003e **Your task:** Read through the code, run it, then extend it with the challenges at the bottom.\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": null,","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"# ============================================================\\n\",","    \"# 💰 Personal Expense Tracker\\n\",","    \"# ============================================================\\n\",","    \"\\n\",","    \"expenses = []  # Our in-memory \\\"database\\\"\\n\",","    \"\\n\",","    \"\\n\",","    \"def add_expense(description, amount, category):\\n\",","    \"    \\\"\\\"\\\"Add a new expense record.\\\"\\\"\\\"\\n\",","    \"    valid_categories = [\\\"food\\\", \\\"transport\\\", \\\"entertainment\\\", \\\"utilities\\\", \\\"health\\\", \\\"other\\\"]\\n\",","    \"    \\n\",","    \"    try:\\n\",","    \"        amount = float(amount)\\n\",","    \"        if amount \u003c= 0:\\n\",","    \"            raise ValueError(\\\"Amount must be positive.\\\")\\n\",","    \"    except ValueError as e:\\n\",","    \"        print(f\\\"Error: {e}\\\")\\n\",","    \"        return\\n\",","    \"    \\n\",","    \"    category = category.lower()\\n\",","    \"    if category not in valid_categories:\\n\",","    \"        print(f\\\"Invalid category. Use: {valid_categories}\\\")\\n\",","    \"        return\\n\",","    \"    \\n\",","    \"    expense = {\\n\",","    \"        \\\"id\\\": len(expenses) + 1,\\n\",","    \"        \\\"description\\\": description.strip().title(),\\n\",","    \"        \\\"amount\\\": amount,\\n\",","    \"        \\\"category\\\": category\\n\",","    \"    }\\n\",","    \"    expenses.append(expense)\\n\",","    \"    print(f\\\"✅ Added: {expense['description']} — ${amount:.2f} [{category}]\\\")\\n\",","    \"\\n\",","    \"\\n\",","    \"def get_summary():\\n\",","    \"    \\\"\\\"\\\"Print a summary of all expenses.\\\"\\\"\\\"\\n\",","    \"    if not expenses:\\n\",","    \"        print(\\\"No expenses recorded yet.\\\")\\n\",","    \"        return\\n\",","    \"    \\n\",","    \"    print(\\\"\\\\n\\\" + \\\"=\\\"*45)\\n\",","    \"    print(\\\"         💰 EXPENSE SUMMARY\\\")\\n\",","    \"    print(\\\"=\\\"*45)\\n\",","    \"    \\n\",","    \"    # Group by category\\n\",","    \"    by_category = {}\\n\",","    \"    for exp in expenses:\\n\",","    \"        cat = exp[\\\"category\\\"]\\n\",","    \"        by_category[cat] = by_category.get(cat, 0) + exp[\\\"amount\\\"]\\n\",","    \"    \\n\",","    \"    total = sum(exp[\\\"amount\\\"] for exp in expenses)\\n\",","    \"    \\n\",","    \"    for category, amount in sorted(by_category.items(), key=lambda x: x[1], reverse=True):\\n\",","    \"        pct = (amount / total) * 100\\n\",","    \"        bar = \\\"█\\\" * int(pct / 5)\\n\",","    \"        print(f\\\"  {category:\u003c15} ${amount:\u003e8.2f}  {pct:\u003e5.1f}% {bar}\\\")\\n\",","    \"    \\n\",","    \"    print(\\\"-\\\"*45)\\n\",","    \"    print(f\\\"  {'TOTAL':\u003c15} ${total:\u003e8.2f}\\\")\\n\",","    \"    print(\\\"=\\\"*45)\\n\",","    \"    print(f\\\"  Total transactions: {len(expenses)}\\\")\\n\",","    \"    print(f\\\"  Average per expense: ${total/len(expenses):.2f}\\\")\\n\",","    \"\\n\",","    \"\\n\",","    \"def find_expensive(threshold):\\n\",","    \"    \\\"\\\"\\\"Find all expenses over a given amount.\\\"\\\"\\\"\\n\",","    \"    big = [e for e in expenses if e[\\\"amount\\\"] \u003e threshold]\\n\",","    \"    if big:\\n\",","    \"        print(f\\\"\\\\n🔍 Expenses over ${threshold}:\\\")\\n\",","    \"        for e in sorted(big, key=lambda x: x[\\\"amount\\\"], reverse=True):\\n\",","    \"            print(f\\\"  • {e['description']:\u003c25} ${e['amount']:.2f}\\\")\\n\",","    \"    else:\\n\",","    \"        print(f\\\"No expenses over ${threshold}.\\\")\\n\",","    \"\\n\",","    \"\\n\",","    \"# ─── Sample Data ───────────────────────────────────────────\\n\",","    \"add_expense(\\\"morning coffee\\\", 4.50, \\\"food\\\")\\n\",",